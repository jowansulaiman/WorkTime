rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasProfile() {
      return signedIn() && exists(currentUserPath());
    }

    function currentUser() {
      return get(currentUserPath());
    }

    function hasUserProfile(uid) {
      return exists(userPath(uid));
    }

    function userProfile(uid) {
      return get(userPath(uid));
    }

    function dataField(data, field, legacyField) {
      return field in data
          ? data[field]
          : (legacyField in data ? data[legacyField] : null);
    }

    function currentOrgId() {
      return dataField(currentUser().data, 'orgId', 'org_id');
    }

    function dataOrgId(data) {
      return dataField(data, 'orgId', 'org_id');
    }

    function dataIsActive(data) {
      return dataField(data, 'isActive', 'is_active');
    }

    function isTruthy(value) {
      return value == true
          || (value is string && value.lower() == 'true')
          || (value is int && value != 0)
          || (value is float && value != 0.0);
    }

    function normalizedRoleValue(value) {
      return value is string
          ? (value.lower() == 'teamleiter' ? 'teamlead' : value.lower())
          : '';
    }

    function roleIsAdminValue(value) {
      return normalizedRoleValue(value) == 'admin';
    }

    function roleIsTeamLeadValue(value) {
      return normalizedRoleValue(value) == 'teamlead';
    }

    function isActiveUser() {
      return hasProfile() && isTruthy(dataIsActive(currentUser().data));
    }

    function isAdmin() {
      return isActiveUser() && roleIsAdminValue(currentUser().data.role);
    }

    function defaultCanViewSchedule() {
      return isActiveUser();
    }

    function defaultCanEditSchedule() {
      return isActiveUser()
          && (
            roleIsAdminValue(currentUser().data.role)
            || roleIsTeamLeadValue(currentUser().data.role)
          );
    }

    function defaultCanViewTimeTracking() {
      return isActiveUser();
    }

    function defaultCanEditTimeEntries() {
      return isActiveUser();
    }

    function defaultCanViewReports() {
      return isActiveUser();
    }

    function hasPermissionField(field) {
      return 'permissions' in currentUser().data
          && currentUser().data.permissions != null
          && field in currentUser().data.permissions;
    }

    function permissionOrDefault(field, fallback) {
      return hasPermissionField(field)
          ? isTruthy(currentUser().data.permissions[field])
          : fallback;
    }

    function defaultCanViewScheduleForRole(role) {
      return true;
    }

    function defaultCanEditScheduleForRole(role) {
      return roleIsAdminValue(role) || roleIsTeamLeadValue(role);
    }

    function defaultCanViewTimeTrackingForRole(role) {
      return true;
    }

    function defaultCanEditTimeEntriesForRole(role) {
      return true;
    }

    function defaultCanViewReportsForRole(role) {
      return true;
    }

    function permissionValueFromData(data, field, fallback) {
      return 'permissions' in data
          && data.permissions != null
          && field in data.permissions
          ? isTruthy(data.permissions[field])
          : fallback;
    }

    function dataCanViewSchedule(data) {
      return permissionValueFromData(
        data,
        'canViewSchedule',
        defaultCanViewScheduleForRole(data.role),
      );
    }

    function dataCanEditSchedule(data) {
      return permissionValueFromData(
        data,
        'canEditSchedule',
        defaultCanEditScheduleForRole(data.role),
      );
    }

    function dataCanViewTimeTracking(data) {
      return permissionValueFromData(
        data,
        'canViewTimeTracking',
        defaultCanViewTimeTrackingForRole(data.role),
      );
    }

    function dataCanEditTimeEntries(data) {
      return permissionValueFromData(
        data,
        'canEditTimeEntries',
        defaultCanEditTimeEntriesForRole(data.role),
      );
    }

    function dataCanViewReports(data) {
      return permissionValueFromData(
        data,
        'canViewReports',
        defaultCanViewReportsForRole(data.role),
      );
    }

    function dataCanManageShifts(data) {
      return isTruthy(dataIsActive(data)) && dataCanEditSchedule(data);
    }

    function userCanManageShifts(uid) {
      return hasUserProfile(uid) && dataCanManageShifts(userProfile(uid).data);
    }

    function permissionsEquivalent(left, right) {
      return dataCanViewSchedule(left) == dataCanViewSchedule(right)
          && dataCanEditSchedule(left) == dataCanEditSchedule(right)
          && dataCanViewTimeTracking(left) == dataCanViewTimeTracking(right)
          && dataCanEditTimeEntries(left) == dataCanEditTimeEntries(right)
          && dataCanViewReports(left) == dataCanViewReports(right);
    }

    function workRuleValueFromData(data, field, fallback) {
      return 'workRuleSettings' in data
          && data.workRuleSettings != null
          && field in data.workRuleSettings
          ? isTruthy(data.workRuleSettings[field])
          : fallback;
    }

    function workRuleSettingsEquivalent(left, right) {
      return workRuleValueFromData(left, 'enforceMinRestTime', true)
              == workRuleValueFromData(right, 'enforceMinRestTime', true)
          && workRuleValueFromData(left, 'enforceBreakAfterSixHours', true)
              == workRuleValueFromData(
                right,
                'enforceBreakAfterSixHours',
                true,
              )
          && workRuleValueFromData(left, 'enforceBreakAfterNineHours', true)
              == workRuleValueFromData(
                right,
                'enforceBreakAfterNineHours',
                true,
              )
          && workRuleValueFromData(left, 'enforceMaxDailyMinutes', true)
              == workRuleValueFromData(
                right,
                'enforceMaxDailyMinutes',
                true,
              )
          && workRuleValueFromData(left, 'enforceMinijobLimit', true)
              == workRuleValueFromData(right, 'enforceMinijobLimit', true)
          && workRuleValueFromData(left, 'warnDailyAverageExceeded', true)
              == workRuleValueFromData(
                right,
                'warnDailyAverageExceeded',
                true,
              )
          && workRuleValueFromData(left, 'warnForwardRotation', true)
              == workRuleValueFromData(right, 'warnForwardRotation', true)
          && workRuleValueFromData(left, 'warnOvertime', true)
              == workRuleValueFromData(right, 'warnOvertime', true)
          && workRuleValueFromData(left, 'warnSundayWork', true)
              == workRuleValueFromData(right, 'warnSundayWork', true);
    }

    function canViewSchedule() {
      return isAdmin()
          || permissionOrDefault('canViewSchedule', defaultCanViewSchedule());
    }

    function canEditSchedule() {
      return isAdmin()
          || permissionOrDefault('canEditSchedule', defaultCanEditSchedule());
    }

    function canViewTimeTracking() {
      return isAdmin()
          || permissionOrDefault(
            'canViewTimeTracking',
            defaultCanViewTimeTracking(),
          );
    }

    function canEditTimeEntries() {
      return isAdmin()
          || permissionOrDefault(
            'canEditTimeEntries',
            defaultCanEditTimeEntries(),
          );
    }

    function canViewReports() {
      return isAdmin()
          || permissionOrDefault('canViewReports', defaultCanViewReports());
    }

    function canManageShifts() {
      return isActiveUser() && canEditSchedule();
    }

    // Warenwirtschaft: verwalten duerfen Admins und Schichtleiter
    // (Mitarbeiter mit Schicht-Bearbeitungsrecht). Ansehen darf jedes
    // aktive Mitglied der Organisation.
    function canManageInventory() {
      return isAdmin() || canManageShifts();
    }

    // Kontakte verwalten: Admins und Schichtleiter (analog Warenwirtschaft) —
    // spiegelt AppUserProfile.canManageContacts.
    function canManageContacts() {
      return isAdmin() || canManageShifts();
    }

    // Kundenfeedback (Beschwerden/Vorschläge/Lob von der öffentlichen /feedback-
    // Seite) verwalten: Admins und Schichtleiter — spiegelt
    // AppUserProfile.canManageFeedback. Anders als Kundenwünsche ist der Eingang
    // NICHT für alle Mitglieder sichtbar (Beschwerden können sensibel sein).
    function canManageFeedback() {
      return isAdmin() || canManageShifts();
    }

    function canReviewAbsenceRequestData(data) {
      return sameOrg(dataOrgId(data))
          && canManageShifts()
          && (
            isAdmin()
            || (
              data.userId != request.auth.uid
              && hasUserProfile(data.userId)
              && !userCanManageShifts(data.userId)
            )
          );
    }

    function canEditOwnPendingAbsenceRequest(before, after) {
      return sameOrg(dataOrgId(before))
          && before.userId == request.auth.uid
          && before.status == 'pending'
          && after.orgId == before.orgId
          && after.userId == before.userId
          && after.employeeName == before.employeeName
          && after.status == before.status
          && after.reviewedByUid == before.reviewedByUid;
    }

    function canManageApprovedVacationRequestData(data) {
      return sameOrg(dataOrgId(data))
          && canManageShifts()
          && data.type == 'vacation'
          && data.status == 'approved'
          && (
            isAdmin()
            || data.userId == request.auth.uid
            || (
              hasUserProfile(data.userId)
              && !userCanManageShifts(data.userId)
            )
          );
    }

    function canEditManagedApprovedVacationRequest(before, after) {
      return canManageApprovedVacationRequestData(before)
          && after.orgId == before.orgId
          && after.userId == before.userId
          && after.employeeName == before.employeeName
          && after.type == before.type
          && after.status == before.status
          && after.reviewedByUid == before.reviewedByUid;
    }

    function canDeleteOwnPendingAbsenceRequest(data) {
      return sameOrg(dataOrgId(data))
          && data.userId == request.auth.uid
          && data.status == 'pending';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function sameOrg(orgId) {
      return isActiveUser() && currentOrgId() == orgId;
    }

    // Org, deren öffentliche Seiten (/wunsch UND /feedback) anonyme
    // Schreibzugriffe annehmen dürfen. MUSS mit AppConfig.defaultOrganizationId
    // (dart-define APP_DEFAULT_ORG_ID) übereinstimmen — sonst werden anonyme
    // Submissions still abgewiesen. Nur DIESE Org ist öffentlich beschreibbar;
    // alle anderen Org-Pfade nicht.
    function publicWishOrg() {
      return 'main-org';
    }

    function inviteIdForCurrentUser() {
      return request.auth.token.email.lower();
    }

    function ownInvitePath() {
      return /databases/$(database)/documents/userInvites/$(inviteIdForCurrentUser());
    }

    function hasOwnInvite() {
      return signedIn() && exists(ownInvitePath());
    }

    function ownInvite() {
      return get(ownInvitePath());
    }

    match /users/{uid} {
      allow read: if (signedIn() && isSelf(uid))
          || (
            isActiveUser()
            && canManageShifts()
            && dataOrgId(resource.data) == currentOrgId()
          );

      allow create: if isSelf(uid)
          && signedIn()
          && request.resource.data.email == request.auth.token.email
          && isTruthy(dataIsActive(request.resource.data))
          && hasOwnInvite()
          && isTruthy(dataIsActive(ownInvite().data))
          && dataOrgId(request.resource.data) == dataOrgId(ownInvite().data)
          && normalizedRoleValue(request.resource.data.role)
              == normalizedRoleValue(ownInvite().data.role)
          && (
            !('permissions' in ownInvite().data)
            || permissionsEquivalent(
              request.resource.data,
              ownInvite().data,
            )
          );

      allow update: if isActiveUser()
          && (
            (
              isSelf(uid)
              && dataOrgId(request.resource.data) == dataOrgId(resource.data)
              && normalizedRoleValue(request.resource.data.role)
                  == normalizedRoleValue(resource.data.role)
              && request.resource.data.email == resource.data.email
              && isTruthy(dataIsActive(request.resource.data))
                  == isTruthy(dataIsActive(resource.data))
              && permissionsEquivalent(
                request.resource.data,
                resource.data,
              )
              && workRuleSettingsEquivalent(
                request.resource.data,
                resource.data,
              )
            )
            || (
              isAdmin()
              && dataOrgId(resource.data) == currentOrgId()
              && dataOrgId(request.resource.data) == currentOrgId()
            )
          );

      allow delete: if false;
    }

    match /userInvites/{inviteId} {
      allow get: if isAdmin()
          || (
            signedIn()
            && inviteId == inviteIdForCurrentUser()
          );

      allow list: if isAdmin();

      allow create: if isAdmin()
          && dataOrgId(request.resource.data) == currentOrgId();

      allow update: if (
            isAdmin()
            && dataOrgId(resource.data) == currentOrgId()
            && dataOrgId(request.resource.data) == currentOrgId()
          ) || (
            signedIn()
            && inviteId == inviteIdForCurrentUser()
            && dataOrgId(request.resource.data) == dataOrgId(resource.data)
            && request.resource.data.email == resource.data.email
            && request.resource.data.emailLower == resource.data.emailLower
            && normalizedRoleValue(request.resource.data.role)
                == normalizedRoleValue(resource.data.role)
            && isTruthy(dataIsActive(request.resource.data))
                == isTruthy(dataIsActive(resource.data))
            && permissionsEquivalent(
              request.resource.data,
              resource.data,
            )
            && request.resource.data.acceptedByUid == request.auth.uid
          );

      allow delete: if isAdmin() && dataOrgId(resource.data) == currentOrgId();
    }

    match /organizations/{orgId} {
      allow read: if sameOrg(orgId);
      allow create, update: if isAdmin() && request.resource.data.name is string;
      allow delete: if false;

      // Remote-Config / Feature-Flags + Mindest-Build-Nummer
      // (no-feature-flags-force-update): von allen Org-Mitgliedern lesbar,
      // nur durch Admins pflegbar.
      match /config/{configId} {
        allow read: if sameOrg(orgId);
        allow write: if isAdmin();
      }

      match /workEntries/{entryId} {
        allow read: if sameOrg(orgId)
            && (
              canManageShifts()
              || (
                resource.data.userId == request.auth.uid
                && (canViewTimeTracking() || canViewReports())
              )
            );

        allow create: if sameOrg(orgId)
            && (
              isAdmin()
              || (
                request.resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            )
            && request.resource.data.orgId == orgId;

        allow update: if sameOrg(orgId)
            && (
              isAdmin()
              || (
                resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            )
            && request.resource.data.orgId == orgId;

        allow delete: if sameOrg(orgId)
            && (
              isAdmin()
              || (
                resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            );
      }

      // Zeitwirtschaft: Stempel-Sessions (ClockEntry, M3). Mitarbeiter lesen/
      // schreiben eigene; Manager/Admin lesen org-weit („wer ist eingestempelt")
      // und können fremde korrigieren. Löschen nur Admin (Buchungen werden sonst
      // soft-deaktiviert). Wie workEntries ein direkter Schreibpfad (Callable-
      // Härtung + {userId}-open-Concurrency später in M7).
      match /clockEntries/{clockEntryId} {
        allow read: if sameOrg(orgId)
            && (
              canManageShifts()
              || (
                resource.data.userId == request.auth.uid
                && canViewTimeTracking()
              )
            );

        allow create: if sameOrg(orgId)
            && (
              canManageShifts()
              || (
                request.resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            )
            && request.resource.data.orgId == orgId;

        allow update: if sameOrg(orgId)
            && (
              canManageShifts()
              || (
                resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            )
            && request.resource.data.orgId == orgId;

        allow delete: if sameOrg(orgId) && isAdmin();
      }

      // Zeitwirtschaft: Stundenkonto-Snapshots (ZeitkontoSnapshot, M4). Lesen:
      // eigene + Manager/Admin. Schreiben: nur Manager/Admin (Snapshots entstehen
      // beim Monatsabschluss/Auszahlung, nie durch den Mitarbeiter selbst).
      match /zeitkontoSnapshots/{snapshotId} {
        allow read: if sameOrg(orgId)
            && (
              canManageShifts()
              || (
                resource.data.userId == request.auth.uid
                && canViewTimeTracking()
              )
            );

        allow create, update: if sameOrg(orgId)
            && canManageShifts()
            && request.resource.data.orgId == orgId;

        allow delete: if sameOrg(orgId) && isAdmin();
      }

      match /workTemplates/{templateId} {
        allow read: if sameOrg(orgId)
            && (
              isAdmin()
              || (
                resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            );

        allow create: if sameOrg(orgId)
            && (
              isAdmin()
              || (
                request.resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            )
            && request.resource.data.orgId == orgId;

        allow update: if sameOrg(orgId)
            && (
              isAdmin()
              || (
                resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            )
            && request.resource.data.orgId == orgId;

        allow delete: if sameOrg(orgId)
            && (
              isAdmin()
              || (
                resource.data.userId == request.auth.uid
                && canEditTimeEntries()
              )
            );
      }

      match /shiftTemplates/{templateId} {
        allow read: if sameOrg(orgId)
            && canManageShifts()
            && resource.data.userId == request.auth.uid;

        allow create: if sameOrg(orgId)
            && canManageShifts()
            && request.resource.data.orgId == orgId
            && request.resource.data.userId == request.auth.uid;

        allow update: if sameOrg(orgId)
            && canManageShifts()
            && resource.data.userId == request.auth.uid
            && request.resource.data.orgId == orgId
            && request.resource.data.userId == request.auth.uid;

        allow delete: if sameOrg(orgId)
            && canManageShifts()
            && resource.data.userId == request.auth.uid;
      }

      match /teams/{teamId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      match /shifts/{shiftId} {
        // Lesen org-weit für die Schichtleitung sowie jeden Mitarbeiter mit
        // Planungs-Einsicht (bewusst geöffnet für die Schichttausch-Auswahl:
        // ein Mitarbeiter muss die Schichten der Kollegen sehen, um eine zum
        // Tausch auszuwählen). Schreiben bleibt managergebunden (siehe unten).
        allow read: if sameOrg(orgId)
            && (canManageShifts() || canViewSchedule());
        allow create: if sameOrg(orgId)
            && canManageShifts()
            && request.resource.data.orgId == orgId;

        allow update: if sameOrg(orgId)
            && canManageShifts()
            && request.resource.data.orgId == orgId;

        allow delete: if sameOrg(orgId) && canManageShifts();
      }

      match /absenceRequests/{requestId} {
        allow read: if sameOrg(orgId)
            && (canManageShifts() || resource.data.userId == request.auth.uid);

        allow create: if sameOrg(orgId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.orgId == orgId;

        allow update: if (
              canReviewAbsenceRequestData(resource.data)
              || canEditManagedApprovedVacationRequest(
                resource.data,
                request.resource.data,
              )
              || canEditOwnPendingAbsenceRequest(
                resource.data,
                request.resource.data,
              )
            )
            && request.resource.data.orgId == orgId
            && request.resource.data.userId == resource.data.userId;

        allow delete: if (canManageShifts() && sameOrg(orgId))
            || canDeleteOwnPendingAbsenceRequest(resource.data);
      }

      // Schichttausch-Anfragen: Antragsteller stellt sie selbst, der
      // Zielkollege nimmt an/ab, die Schichtleitung bestätigt/lehnt ab.
      match /shiftSwapRequests/{requestId} {
        allow read: if sameOrg(orgId) && (
              canManageShifts()
              || resource.data.requesterUid == request.auth.uid
              || resource.data.targetUid == request.auth.uid
            );
        allow create: if sameOrg(orgId)
            && request.resource.data.requesterUid == request.auth.uid
            && request.resource.data.orgId == orgId
            && request.resource.data.status == 'pending';
        allow update: if sameOrg(orgId)
            && request.resource.data.orgId == resource.data.orgId
            && request.resource.data.requesterUid == resource.data.requesterUid
            && request.resource.data.targetUid == resource.data.targetUid
            && (
              // Kollege nimmt an / lehnt ab (nur solange offen).
              (resource.data.targetUid == request.auth.uid
                  && resource.data.status == 'pending'
                  && request.resource.data.status in ['accepted_by_colleague', 'declined_by_colleague'])
              // Antragsteller zieht zurück (solange noch nicht bestätigt).
              || (resource.data.requesterUid == request.auth.uid
                  && resource.data.status in ['pending', 'accepted_by_colleague']
                  && request.resource.data.status == 'cancelled')
              // Chef bestätigt / lehnt eine angenommene Anfrage ab.
              || (canManageShifts()
                  && resource.data.status == 'accepted_by_colleague'
                  && request.resource.data.status in ['confirmed', 'rejected_by_manager'])
            );
        allow delete: if sameOrg(orgId) && (
              canManageShifts()
              || (resource.data.requesterUid == request.auth.uid
                  && resource.data.status == 'pending')
            );
      }

      // Schicht-Gutschriften (einseitiger Tausch). Anlage nur durch die
      // Schichtleitung (entsteht bei der Chef-Bestätigung); einlösen/stornieren
      // dürfen die Schichtleitung und die beteiligten Mitarbeiter.
      match /swapCredits/{creditId} {
        allow read: if sameOrg(orgId) && (
              canManageShifts()
              || resource.data.creditorUid == request.auth.uid
              || resource.data.debtorUid == request.auth.uid
            );
        allow create: if sameOrg(orgId)
            && canManageShifts()
            && request.resource.data.orgId == orgId;
        allow update: if sameOrg(orgId)
            && request.resource.data.orgId == resource.data.orgId
            && request.resource.data.creditorUid == resource.data.creditorUid
            && request.resource.data.debtorUid == resource.data.debtorUid
            && (
              canManageShifts()
              || resource.data.creditorUid == request.auth.uid
              || resource.data.debtorUid == request.auth.uid
            );
        allow delete: if sameOrg(orgId) && canManageShifts();
      }

      match /sites/{siteId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      match /qualifications/{qualificationId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      match /employmentContracts/{contractId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      match /employeeSiteAssignments/{assignmentId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Schicht-Vorgaben je Mitarbeiter (Doc-ID = userId). Lesen: sameOrg
      // (Verteiler/Anzeige). Schreiben: Chef/Teamleitung (defaultCanEditSchedule).
      match /shiftPreferences/{prefUserId} {
        allow read: if sameOrg(orgId);
        allow create, update: if defaultCanEditSchedule()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId
            && request.resource.data.userId == prefUserId;
        allow delete: if defaultCanEditSchedule() && sameOrg(orgId);
      }

      match /ruleSets/{ruleSetId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      match /travelTimeRules/{ruleId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // --- Personal-Bereich (nur Admin) -----------------------------------

      match /workTasks/{taskId} {
        allow read: if sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Lohndaten enthalten Verguetungsinformationen -> Lesen Admin-only.
      match /payrollRecords/{recordId} {
        // M7-Self-Read (L2): eigene Lohnabrechnung lesbar (Doc trägt userId),
        // Schreiben bleibt admin-only.
        allow read: if sameOrg(orgId)
            && (
              isAdmin()
              || (resource.data.userId == request.auth.uid
                  && canViewTimeTracking())
            );
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Lohn-Stammdaten je Mitarbeiter (Steuerklasse/SV/Bundesland) -> Admin-only.
      match /payrollProfiles/{userId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Personal-Stammakte je Mitarbeiter (HR-Stammdaten: Anschrift, SV-/Bank-
      // /Steuerdaten, Eintritt/Austritt) -> Admin-only (personenbezogene Daten).
      match /employeeProfiles/{userId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Sollzeit-Profile (Arbeitszeitmodelle je MA, gültig-ab-versioniert).
      // M7-Self-Read (L2): eigenes Profil lesbar (Doc trägt userId), damit
      // Stundenkonto/Mein-Monatsabschluss das Soll berechnen; Schreiben (steuert
      // Lohn/Stundenkonto/Urlaubsanspruch) bleibt admin-only.
      match /sollzeitProfiles/{profileId} {
        allow read: if sameOrg(orgId)
            && (
              isAdmin()
              || (resource.data.userId == request.auth.uid
                  && canViewTimeTracking())
            );
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Org-/jahr-spezifische Lohn-Konfiguration (SV-/AG-Sätze inkl. U1/U2/InsO/
      // UV) -> Admin-only (steuern Lohn-/Arbeitgeberkostenrechnung). Doc-ID = Jahr.
      match /payrollConfig/{jahr} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // HR-Sub-Entitäten je Mitarbeiter (Kinder/Qualifikationen/Ausbildung) ->
      // Admin-only (personenbezogene HR-Daten, teils lohnsteuerrelevant).
      match /employeeChildren/{childId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }
      match /employeeQualifications/{qualificationId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }
      match /employeeAusbildungen/{ausbildungId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Urlaubskonto: Jahres-Vortrag (Doc-ID {userId}-{jahr}) + Korrektur-Ledger
      // -> Admin-only (urlaubsrechtlich relevant).
      match /urlaubskontoJahre/{kontoId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }
      match /urlaubsanpassungen/{anpassungId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }
      // Lohnarten-Katalog (M-L): org-weite Lohnart-Vorlagen -> Admin-only.
      match /payLineTypes/{typeId} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Finanzen (Kostenrechnung): Kostenstellen, Kostenarten, Buchungsjournal
      // und Budgets -> Admin-only (betriebswirtschaftliche Daten).
      match /costCenters/{id} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }
      match /costTypes/{id} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }
      match /journalEntries/{id} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }
      match /budgets/{id} {
        allow read: if isAdmin() && sameOrg(orgId);
        allow create, update: if isAdmin()
            && sameOrg(orgId)
            && request.resource.data.orgId == orgId;
        allow delete: if isAdmin() && sameOrg(orgId);
      }

      // Änderungsprotokoll (Audit-Trail): append-only. Lesen nur Admins;
      // anlegen darf jedes aktive Org-Mitglied für sich selbst; nie ändern/löschen.
      match /auditLog/{entryId} {
        allow read: if isAdmin() && sameOrg(orgId);
        // Anlegen nur für sich selbst (actorUid an den Aufrufer gepinnt),
        // damit Einträge nicht im Namen anderer gefälscht werden können.
        allow create: if sameOrg(orgId)
            && request.resource.data.orgId == orgId
            && (!('actorUid' in request.resource.data)
                || request.resource.data.actorUid == null
                || request.resource.data.actorUid == request.auth.uid)
            && request.resource.data.action in
                 ['created', 'updated', 'deleted', 'corrected'];
        allow update, delete: if false;
      }

      // --- Warenwirtschaft ------------------------------------------------

      match /suppliers/{supplierId} {
        allow read: if sameOrg(orgId);
        allow create, update: if sameOrg(orgId)
            && canManageInventory()
            && request.resource.data.orgId == orgId;
        allow delete: if sameOrg(orgId) && canManageInventory();
      }

      match /products/{productId} {
        allow read: if sameOrg(orgId);
        allow create, update: if sameOrg(orgId)
            && canManageInventory()
            && request.resource.data.orgId == orgId;
        allow delete: if sameOrg(orgId) && canManageInventory();

        // Preis-Historie ist ein Audit-Log (wie stockMovements): anlegen ja,
        // aendern/loeschen nein. Eigene Subcollection statt neuer
        // StockMovementType, damit Bewegung (Menge) und Preis sauber getrennt
        // bleiben. Feld-Allowlist gegen Mass Assignment (BOPLA).
        match /priceHistory/{entryId} {
          allow read: if sameOrg(orgId);
          allow create: if sameOrg(orgId)
              && canManageInventory()
              && request.resource.data.orgId == orgId
              && request.resource.data.keys().hasOnly([
                   'orgId', 'productId', 'field', 'oldCents', 'newCents',
                   'changedByUid', 'changedAt'
                 ])
              && request.resource.data.field in ['purchase', 'selling']
              // oldCents/newCents sind nullable (int?) -> null/absent zulassen.
              && (!('oldCents' in request.resource.data)
                   || request.resource.data.oldCents == null
                   || request.resource.data.oldCents is number)
              && (!('newCents' in request.resource.data)
                   || request.resource.data.newCents == null
                   || request.resource.data.newCents is number)
              && (!('changedByUid' in request.resource.data)
                   || request.resource.data.changedByUid == null
                   || request.resource.data.changedByUid == request.auth.uid);
          allow update, delete: if false;
        }
      }

      match /purchaseOrders/{orderId} {
        allow read: if sameOrg(orgId);
        allow create, update: if sameOrg(orgId)
            && canManageInventory()
            && request.resource.data.orgId == orgId;
        allow delete: if sameOrg(orgId) && canManageInventory();
      }

      // Kundenbestellungen (Sonderbestellungen) – wie Lieferantenbestellungen
      // direkte Writes, gated ueber dieselbe Warenwirtschafts-Berechtigung.
      match /customerOrders/{orderId} {
        allow read: if sameOrg(orgId);
        allow create, update: if sameOrg(orgId)
            && canManageInventory()
            && request.resource.data.orgId == orgId;
        allow delete: if sameOrg(orgId) && canManageInventory();
      }

      // Öffentliche Kundenwünsche (über die Webseite /wunsch). EINZIGER
      // öffentlicher Schreibpfad der App: anonyme Kunden (request.auth != null,
      // anonymes Sign-in) dürfen ANLEGEN, aber nichts lesen/ändern. Streng
      // allowlisted (wie stockMovements) gegen Mass Assignment (BOPLA):
      //  - orgId an den publizierenden Laden gepinnt,
      //  - status fest 'neu', source fest 'public_web',
      //  - createdAt == request.time (Serverzeit, nicht fälschbar),
      //  - Längen-/Typgrenzen gegen Müll/Abuse.
      // Spam-Schutz darüber hinaus = App Check (im Projekt aktivieren!).
      // Lesen/Verwalten wie Kundenbestellungen (aktive Mitglieder / Manager).
      match /customerWishes/{wishId} {
        allow read: if sameOrg(orgId);
        allow update: if sameOrg(orgId)
            && canManageInventory()
            && request.resource.data.orgId == orgId;
        allow delete: if sameOrg(orgId) && canManageInventory();

        allow create: if request.auth != null
            && request.resource.data.orgId == publicWishOrg()
            && orgId == publicWishOrg()
            && request.resource.data.keys().hasOnly([
                 'orgId', 'referenceCode', 'storeName', 'category', 'wishText',
                 'quantity', 'desiredDate', 'customerName', 'customerContact',
                 'status', 'source', 'createdAt'
               ])
            && request.resource.data.keys().hasAll([
                 'orgId', 'referenceCode', 'category', 'wishText', 'quantity',
                 'status', 'source', 'createdAt'
               ])
            && request.resource.data.status == 'neu'
            && request.resource.data.source == 'public_web'
            && request.resource.data.category in
                 ['magazine', 'cigarettes', 'tobacco', 'other']
            && request.resource.data.referenceCode is string
            && request.resource.data.referenceCode.size() >= 1
            && request.resource.data.referenceCode.size() <= 40
            && request.resource.data.wishText is string
            && request.resource.data.wishText.size() >= 1
            && request.resource.data.wishText.size() <= 2000
            // Bewusst `is int` (strenger als `is number` bei oldCents/
            // quantityDelta): der reale cloud_firestore-Client serialisiert den
            // Dart-int als Firestore-Integer; gegen rohe REST-Angreifer ist die
            // Ganzzahl-Pflicht zusätzlicher Schutz.
            && request.resource.data.quantity is int
            && request.resource.data.quantity >= 1
            && request.resource.data.quantity <= 100000
            && request.resource.data.storeName is string
            && request.resource.data.storeName.size() <= 120
            && (!('customerName' in request.resource.data)
                 || request.resource.data.customerName == null
                 || (request.resource.data.customerName is string
                     && request.resource.data.customerName.size() <= 200))
            && (!('customerContact' in request.resource.data)
                 || request.resource.data.customerContact == null
                 || (request.resource.data.customerContact is string
                     && request.resource.data.customerContact.size() <= 200))
            && (!('desiredDate' in request.resource.data)
                 || request.resource.data.desiredDate == null
                 || request.resource.data.desiredDate is timestamp)
            && request.resource.data.createdAt == request.time;
      }

      // Öffentliches Kundenfeedback (über die Webseite /feedback): Beschwerden,
      // Verbesserungsvorschläge und Lob. Zweiter öffentlicher Schreibpfad neben
      // customerWishes — gleiche Härtung: anonyme Kunden (request.auth != null)
      // dürfen ANLEGEN, aber nichts lesen/ändern. Streng allowlisted gegen Mass
      // Assignment (BOPLA):
      //  - orgId an den publizierenden Laden gepinnt (publicWishOrg),
      //  - status fest 'neu', source fest 'public_web',
      //  - createdAt == request.time (Serverzeit, nicht fälschbar),
      //  - Längen-/Typ-/Wertgrenzen gegen Müll/Abuse (rating 1–5).
      // Spam-Schutz darüber hinaus = App Check (im Projekt aktivieren!).
      // Lesen/Verwalten NUR Manager (canManageFeedback) — Beschwerden können
      // sensibel sein, daher KEIN read=sameOrg wie bei customerWishes.
      match /customerFeedback/{feedbackId} {
        allow read: if sameOrg(orgId) && canManageFeedback();
        allow update: if sameOrg(orgId)
            && canManageFeedback()
            && request.resource.data.orgId == orgId;
        allow delete: if sameOrg(orgId) && canManageFeedback();

        allow create: if request.auth != null
            && request.resource.data.orgId == publicWishOrg()
            && orgId == publicWishOrg()
            && request.resource.data.keys().hasOnly([
                 'orgId', 'referenceCode', 'type', 'message', 'storeName',
                 'rating', 'incidentDate', 'customerName', 'customerContact',
                 'status', 'source', 'createdAt'
               ])
            && request.resource.data.keys().hasAll([
                 'orgId', 'referenceCode', 'type', 'message', 'status',
                 'source', 'createdAt'
               ])
            && request.resource.data.status == 'neu'
            && request.resource.data.source == 'public_web'
            && request.resource.data.type in
                 ['complaint', 'suggestion', 'praise']
            && request.resource.data.referenceCode is string
            && request.resource.data.referenceCode.size() >= 1
            && request.resource.data.referenceCode.size() <= 40
            && request.resource.data.message is string
            && request.resource.data.message.size() >= 1
            && request.resource.data.message.size() <= 2000
            && request.resource.data.storeName is string
            && request.resource.data.storeName.size() <= 120
            // rating ist optional (int?) -> null/absent zulassen, sonst 1..5.
            && (!('rating' in request.resource.data)
                 || request.resource.data.rating == null
                 || (request.resource.data.rating is int
                     && request.resource.data.rating >= 1
                     && request.resource.data.rating <= 5))
            && (!('customerName' in request.resource.data)
                 || request.resource.data.customerName == null
                 || (request.resource.data.customerName is string
                     && request.resource.data.customerName.size() <= 200))
            && (!('customerContact' in request.resource.data)
                 || request.resource.data.customerContact == null
                 || (request.resource.data.customerContact is string
                     && request.resource.data.customerContact.size() <= 200))
            && (!('incidentDate' in request.resource.data)
                 || request.resource.data.incidentDate == null
                 || request.resource.data.incidentDate is timestamp)
            && request.resource.data.createdAt == request.time;
      }

      // Wochen-Bestellkorb je Laden (Doc-ID = siteId, Singleton). BEWUSST
      // breiterer Schreibpfad als der Rest der Warenwirtschaft: JEDES aktive
      // Mitglied (auch Mitarbeiter ohne Verwaltungsrecht) darf Positionen in den
      // gemeinsamen Korb legen/aendern – das ist der Kern des Features ("Sorte
      // ist leer -> in den Korb"). sameOrg() verlangt bereits ein aktives
      // Org-Mitglied. Loeschen (Korb-Doc entfernen) bleibt Managern vorbehalten;
      // das Leeren nach dem Checkout laeuft als Update auf leere items.
      match /orderCarts/{siteId} {
        allow read: if sameOrg(orgId);
        // Body an den Pfad binden: orgId muss passen UND das siteId-Feld muss
        // der Doc-ID entsprechen (keine Korb-Docs mit abweichender/fremder
        // siteId). Feld-Allowlist + Typ-/Groessengrenzen gegen Mass Assignment
        // (BOPLA), kind fest auf 'cart', und updatedByUid an den Aufrufer
        // gebunden (Audit-Spoofing) — analog zu stockMovements/customerWishes
        // (probleme #11/#60/#61). Pro-Item-addedByUid ist in Rules nicht
        // pruefbar und gilt als nicht sicherheitsrelevant.
        allow create, update: if sameOrg(orgId)
            && request.resource.data.orgId == orgId
            && request.resource.data.siteId == siteId
            && request.resource.data.keys().hasOnly([
                 'orgId', 'siteId', 'siteName', 'kind', 'items',
                 'updatedByUid', 'updatedAt'
               ])
            && request.resource.data.kind == 'cart'
            && request.resource.data.items is list
            && request.resource.data.items.size() <= 500
            && (request.resource.data.updatedByUid == request.auth.uid
                 || request.resource.data.updatedByUid == null);
        allow delete: if sameOrg(orgId) && canManageInventory();
      }

      // Standard-Wochenliste je Laden (Doc-ID = siteId): Manager-kuratierte
      // Grundbestellung, die den Korb vorbefuellt. Nur Verwaltung schreibt.
      match /weeklyOrderLists/{siteId} {
        allow read: if sameOrg(orgId);
        // Gleiche BOPLA-Haertung wie orderCarts; kind fest 'weekly_template'.
        allow create, update: if sameOrg(orgId)
            && canManageInventory()
            && request.resource.data.orgId == orgId
            && request.resource.data.siteId == siteId
            && request.resource.data.keys().hasOnly([
                 'orgId', 'siteId', 'siteName', 'kind', 'items',
                 'updatedByUid', 'updatedAt'
               ])
            && request.resource.data.kind == 'weekly_template'
            && request.resource.data.items is list
            && request.resource.data.items.size() <= 500
            && (request.resource.data.updatedByUid == request.auth.uid
                 || request.resource.data.updatedByUid == null);
        allow delete: if sameOrg(orgId) && canManageInventory();
      }

      // Kuehlschrank-Nachfuellliste je Laden (Doc-ID = siteId): geteilte
      // Checkliste „was muss aus dem Lager in den Kuehlschrank?". Wie der
      // Bestellkorb darf JEDES aktive Mitglied Positionen setzen/abhaken
      // (breiterer Schreibpfad als der Rest der Warenwirtschaft) — kein
      // Verwaltungsrecht noetig. Loeschen (Doc entfernen) bleibt Managern
      // vorbehalten; das Leeren laeuft als Update auf leere items. Gleiche
      // BOPLA-Haertung wie orderCarts (Feld-Allowlist, siteId an Doc-ID,
      // updatedByUid an den Aufrufer gebunden), aber ohne 'kind'-Feld.
      match /fridgeRefillLists/{siteId} {
        allow read: if sameOrg(orgId);
        allow create, update: if sameOrg(orgId)
            && request.resource.data.orgId == orgId
            && request.resource.data.siteId == siteId
            && request.resource.data.keys().hasOnly([
                 'orgId', 'siteId', 'siteName', 'items',
                 'updatedByUid', 'updatedAt'
               ])
            && request.resource.data.items is list
            && request.resource.data.items.size() <= 500
            && (request.resource.data.updatedByUid == request.auth.uid
                 || request.resource.data.updatedByUid == null);
        allow delete: if sameOrg(orgId) && canManageInventory();
      }

      // Kontakte (Kunden/Lieferanten/Partner/Behoerden) – direkte Writes,
      // lesen alle aktiven Mitglieder, verwalten Admins + Schichtleiter.
      match /contacts/{contactId} {
        allow read: if sameOrg(orgId);
        allow create, update: if sameOrg(orgId)
            && canManageContacts()
            && request.resource.data.orgId == orgId;
        allow delete: if sameOrg(orgId) && canManageContacts();
      }

      // Bestandsbewegungen sind ein Audit-Log: anlegen ja, aendern/loeschen nein.
      // Feld-Allowlist + Typ-/Wertpruefung gegen Mass Assignment (BOPLA) und
      // Manipulation des Audit-Logs (counters-bopla-no-monotonic-check).
      match /stockMovements/{movementId} {
        allow read: if sameOrg(orgId);
        allow create: if sameOrg(orgId)
            && canManageInventory()
            && request.resource.data.orgId == orgId
            && request.resource.data.keys().hasOnly([
                 'orgId', 'siteId', 'productId', 'productName', 'type',
                 'quantityDelta', 'balanceAfter', 'reason', 'relatedOrderId',
                 'createdByUid', 'createdAt'
               ])
            && request.resource.data.type in
                 ['receipt', 'issue', 'adjustment', 'stocktake', 'transfer']
            && request.resource.data.quantityDelta is number
            // balanceAfter ist im Modell nullable (int?) -> null/absent zulassen.
            && (!('balanceAfter' in request.resource.data)
                 || request.resource.data.balanceAfter == null
                 || request.resource.data.balanceAfter is number)
            && (!('createdByUid' in request.resource.data)
                 || request.resource.data.createdByUid == null
                 || request.resource.data.createdByUid == request.auth.uid);
        allow update, delete: if false;
      }

      // Fortlaufende Zaehler (z.B. Bestellnummern): seq muss ganzzahlig sein und
      // darf bei Updates nie sinken (sonst Bestellnummern-Kollisionen).
      match /counters/{counterId} {
        allow read: if sameOrg(orgId);
        allow create: if sameOrg(orgId) && canManageInventory()
            && request.resource.data.seq is int
            && request.resource.data.seq >= 0;
        allow update: if sameOrg(orgId) && canManageInventory()
            && request.resource.data.seq is int
            && request.resource.data.seq >= resource.data.seq;
        allow delete: if false;
      }
    }
  }
}
