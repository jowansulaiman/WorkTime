rules_version = '2';

// Firebase Storage Security Rules (PA-3, digitale Personalakte).
// Einziger Storage-Use-Case bislang: Mitarbeiter-Dokumente. Alles andere ist
// standardmäßig gesperrt (kein `match /{allPaths=**}`-Fallback mit Zugriff).
service firebase.storage {
  match /b/{bucket}/o {

    // employee-documents/{orgId}/{userId}/{docId}
    //  - Admin der Org: lesen/schreiben/löschen.
    //  - Mitarbeiter selbst: NUR lesen, und NUR wenn das zugehörige
    //    Metadaten-Doc `visibleToEmployee == true` trägt (Cross-Service-Read
    //    auf Firestore). Kiosk-Gerätekonto (role 'kiosk') NIE.
    //  - Upload: nur Admin, < 15 MB, contentType in Whitelist (pdf/jpg/png).
    match /employee-documents/{orgId}/{userId}/{docId} {
      function signedIn() {
        return request.auth != null;
      }
      function callerDoc() {
        return firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        );
      }
      function callerOrg() {
        return callerDoc().data.orgId;
      }
      function callerRole() {
        return callerDoc().data.role;
      }
      // M2/GB (Sicherheits-Audit 2026-07): deaktivierte Konten behalten ihr
      // Auth-Token bis zum Ablauf — ohne isActive-Check koennte ein
      // entlassener Admin weiter Dokumente lesen/schreiben. Tolerant wie
      // isTruthy in firestore.rules (bool/String/Zahl).
      function callerActive() {
        return callerDoc().data.isActive == true
            || callerDoc().data.isActive == 'true'
            || callerDoc().data.isActive == 1;
      }
      function isAdmin() {
        return signedIn()
            && callerActive()
            && callerRole() == 'admin'
            && callerOrg() == orgId;
      }
      function isSelfVisible() {
        return signedIn()
            && callerActive()
            && request.auth.uid == userId
            && callerOrg() == orgId
            && callerRole() != 'kiosk'
            && firestore.get(
                 /databases/(default)/documents/organizations/$(orgId)/employeeDocuments/$(docId)
               ).data.visibleToEmployee == true;
      }

      allow read: if isAdmin() || isSelfVisible();

      // `write` deckt create/update/delete. Beim Löschen ist request.resource
      // null → dann keine Größen-/Typ-Prüfung (nur Admin-Gate).
      allow write: if isAdmin()
          && (
            request.resource == null
            || (
              request.resource.size < 15 * 1024 * 1024
              && request.resource.contentType
                  .matches('application/pdf|image/jpeg|image/png')
            )
          );
    }

    // organizations/{orgId}/contacts/{contactId}/avatar.{ext} — Kontakt-Avatar.
    //  - Lesen: jedes aktive Org-Mitglied (Avatar in der Kontakt-Detailseite).
    //  - Schreiben: Admin ODER Schichtleitung (= canManageContacts), < 5 MB,
    //    image/*. Kiosk-Gerätekonto NIE.
    match /organizations/{orgId}/contacts/{contactId}/{fileName} {
      function signedIn() {
        return request.auth != null;
      }
      function callerDoc() {
        return firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        );
      }
      function callerOrg() {
        return callerDoc().data.orgId;
      }
      function callerRole() {
        return callerDoc().data.role;
      }
      // M2/GB: siehe employee-documents — isActive ist Pflicht.
      function callerActive() {
        return callerDoc().data.isActive == true
            || callerDoc().data.isActive == 'true'
            || callerDoc().data.isActive == 1;
      }
      function sameActiveOrg() {
        return signedIn()
            && callerActive()
            && callerOrg() == orgId
            && callerRole() != 'kiosk';
      }
      function canManageContacts() {
        return sameActiveOrg()
            && (callerRole() == 'admin' || callerRole() == 'teamlead');
      }

      allow read: if sameActiveOrg();
      allow write: if canManageContacts()
          && (
            request.resource == null
            || (
              request.resource.size < 5 * 1024 * 1024
              && request.resource.contentType.matches('image/.*')
            )
          );
    }

    // organizations/{orgId}/signage/{fileName} — Werbebilder der digitalen
    // Displays (Store-TVs).
    //  - Schreiben: NUR Admin der Org, < 10 MB, image/*.
    //  - Lesen: NUR Admin. Wird gebraucht, weil der Upload direkt danach
    //    getDownloadURL() aufruft (das verlangt Leserecht) und die Verwaltung
    //    die Vorschau zeigt. Der FERNSEHER liest NICHT ueber diese Rules — er
    //    laedt das Bild ueber die tokenisierte Download-URL (Bearer-Token in der
    //    URL, umgeht die Storage-Rules), daher KEINE oeffentliche Leseregel.
    match /organizations/{orgId}/signage/{fileName} {
      function signedIn() {
        return request.auth != null;
      }
      function callerDoc() {
        return firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        );
      }
      function callerOrg() {
        return callerDoc().data.orgId;
      }
      function callerRole() {
        return callerDoc().data.role;
      }
      // M2/GB: siehe employee-documents — isActive ist Pflicht.
      function callerActive() {
        return callerDoc().data.isActive == true
            || callerDoc().data.isActive == 'true'
            || callerDoc().data.isActive == 1;
      }
      function isAdmin() {
        return signedIn()
            && callerActive()
            && callerRole() == 'admin'
            && callerOrg() == orgId;
      }

      allow read: if isAdmin();
      allow write: if isAdmin()
          && (
            request.resource == null
            || (
              request.resource.size < 10 * 1024 * 1024
              && request.resource.contentType.matches('image/.*')
            )
          );
    }
  }
}
